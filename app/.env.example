# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (optional in dev, required for non-default production deployments)
# In dev: not needed — Vite proxy handles /api/* → localhost:3001
# In production: set to the full backend URL (e.g., https://resume-agent-server.up.railway.app)
# When set, the frontend calls the backend directly (bypassing Vercel rewrites).
# The server must have ALLOWED_ORIGINS configured to include the frontend domain.
# VITE_API_URL=https://your-backend.up.railway.app

# Social auth provider allowlist (optional). Comma-separated list of provider
# ids to expose on the AuthGate. Hides buttons for providers whose Supabase
# integration isn't configured yet. Leave unset to show every provider in
# auth-providers.ts (relies on the runtime "provider not enabled" fallback).
# Valid ids: google, azure, linkedin_oidc.
# VITE_SOCIAL_PROVIDERS=google,linkedin_oidc
